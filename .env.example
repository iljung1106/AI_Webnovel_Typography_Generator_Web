# Copy this file to `.env` and fill in your real keys if you want local env loading.

# For LayoutModule/typography_layout.py
OPENROUTER_API_KEY=your-openrouter-api-key

# For ImageGenerationModule/comfy_cloud.py
COMFY_CLOUD_API_KEY=your-comfy-cloud-api-key

# Production service frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Production service backend/worker
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APP_ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ALLOW_DEV_AUTH=true
SUPABASE_STORAGE_BUCKET=project-assets
SIGNED_URL_EXPIRES_IN=300
JOB_POLL_INTERVAL_SECONDS=2
GENERATION_BATCH_TIMEOUT_SECONDS=300
SUPABASE_REQUEST_TIMEOUT_SECONDS=30
WORKER_ID=typography-worker
USE_CLAIM_JOB_RPC=true
CLAIM_JOB_RPC_NAME=claim_next_job
WORKER_OUTPUT_DIR=worker_output
TYPOGRAPHY_RESULTS_BUCKET=typography-results
UPLOAD_GENERATED_ASSETS=true
