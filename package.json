{
  "name": "ai-webnovel-typography-generator",
  "private": true,
  "version": "0.1.0",
  "description": "Production service skeleton for the AI webnovel typography generator.",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
